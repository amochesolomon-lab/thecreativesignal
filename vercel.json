{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/cron/broadcast", "destination": "server.js" },
    { "source": "/api/subscribe", "destination": "server.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/broadcast",
      "schedule": "0 9 * * 0"
    }
  ]
}